{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epsilon.run/schemas/control-plane-event.schema.json",
  "title": "Epsilon Control Plane Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "emitted_at",
    "run",
    "source"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "run.started",
        "run.completed",
        "run.failed",
        "stage.started",
        "stage.completed",
        "stage.failed",
        "task.enqueued",
        "task.started",
        "task.completed",
        "task.failed",
        "task.retried",
        "artifact.produced",
        "worker.heartbeat",
        "usage.reported"
      ]
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "workflow_name": {
          "type": "string"
        },
        "topology": {
          "type": "string"
        },
        "project": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component"
      ],
      "properties": {
        "component": {
          "type": "string",
          "enum": [
            "orchestrator",
            "worker_daemon",
            "agent_main",
            "broker",
            "reducer",
            "adapter"
          ]
        },
        "host": {
          "type": "string"
        },
        "pid": {
          "type": "integer"
        }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stage_id": {
          "type": "string"
        },
        "stage_name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "success",
            "failure"
          ]
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string"
        },
        "task_type": {
          "type": "string"
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "success",
            "failure",
            "retrying"
          ]
        },
        "executor": {
          "type": "string"
        }
      }
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "worker_id": {
          "type": "string"
        },
        "lease_id": {
          "type": "string"
        },
        "heartbeat_interval_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string"
        },
        "prompt_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "response_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
