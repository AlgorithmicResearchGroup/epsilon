            "openai/gpt-5.2",
            "anthropic/claude-opus-4-6"
        ],
        "limits": {
            "max_tokens_default": 512,
            "max_tokens_min": 32,
            "max_tokens_max": 1024,
            "temperature_default": 0.0,
            "temperature_min": 0.0,
            "temperature_max": 0.7,
            "timeout_seconds_default": 30,
            "timeout_seconds_min": 5,
            "timeout_seconds_max": 60,
            "prompt_max_chars": 12000,
            "response_max_chars": 12000
        }
